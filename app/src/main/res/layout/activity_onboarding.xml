<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <!-- Top: skip button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:paddingHorizontal="24dp"
        android:paddingTop="48dp"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/btnSkip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Passer"
            android:textColor="@color/text_hint"
            android:textSize="16sp"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <!-- Image -->
    <ImageView
        android:id="@+id/ivOnboardingImage"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scaleType="centerInside"
        android:paddingHorizontal="48dp"
        android:paddingVertical="24dp"/>

    <!-- Content card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_onboarding_card"
        android:paddingHorizontal="28dp"
        android:paddingTop="32dp"
        android:paddingBottom="24dp">

        <!-- Page indicator -->
        <TextView
            android:id="@+id/tvPageIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/accent"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <!-- Title -->
        <TextView
            android:id="@+id/tvOnboardingTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="26sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"/>

        <!-- Description -->
        <TextView
            android:id="@+id/tvOnboardingDescription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="15sp"
            android:lineSpacingExtra="4dp"
            android:layout_marginTop="12dp"/>

        <!-- Steps -->
        <TextView
            android:id="@+id/tvOnboardingSteps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/accent"
            android:textSize="14sp"
            android:lineSpacingExtra="6dp"
            android:layout_marginTop="20dp"/>

        <!-- Bottom row: indicator dots + next button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="28dp">

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNext"
                android:layout_width="wrap_content"
                android:layout_height="52dp"
                android:text="Suivant"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="@color/accent"
                android:textColor="@color/bg_dark"
                app:cornerRadius="14dp"
                android:paddingHorizontal="36dp"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
